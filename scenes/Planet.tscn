[sub_resource type="Shader" id=4]
code = "shader_type spatial;

render_mode blend_mix, depth_draw_alpha_prepass, cull_back;

uniform sampler2D noise_texture;

uniform float radius = 1.0;
uniform float speed = 0.005;
uniform float brightness = 0.5;
uniform float threshold = 1.2;
uniform float fluffiness = 0.1;

void vertex() {
	vec3 dir = normalize(VERTEX);
	VERTEX = dir * radius;
}

void fragment() {

	vec2 uv1 = fract(UV + TIME * 2.5 * speed * 0.1);
	vec2 uv2 = fract(UV + TIME * (2.5 + fluffiness * 3.0) * speed * 0.1);

	vec4 noise_1 = texture(noise_texture, uv1);
	vec4 noise_2 = texture(noise_texture, uv2);

	vec4 combined_noise = noise_1 + noise_2;

	ALBEDO = combined_noise.rgb * brightness;

	if (combined_noise.r < threshold){
		ALPHA = 0.0;
	} else {
		ALPHA = 1.0;
	}
}"

