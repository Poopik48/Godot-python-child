[ext_resource path="res://planet.py" type="Script" id=1]

[sub_resource type="Shader" id=1]
code = "shader_type spatial;

render_mode cull_back, depth_draw_opaque;

uniform float radius = 1.0;
uniform float height_scale = 0.12;

// noise
uniform int octaves = 5;
uniform float lacunarity = 2.0;
uniform float gain = 0.5;
uniform float noise_scale = 3.0;

uniform vec3 noise_offset = vec3(0.0,0.0,0.0);

//биомы
uniform float sea_level = 0.0;
uniform float beach_size = 0.03;
uniform float snow_level = 0.62;

uniform vec4 deep_water_color = vec4(0.03,0.10,0.22,1.0);
uniform vec4 shallow_water_color = vec4(0.09,0.25,0.45,1.0);
uniform vec4 beach_color = vec4(0.72,0.67,0.45,1.0);
uniform vec4 grass_color = vec4(0.16,0.40,0.18,1.0);
uniform vec4 rock_color = vec4(0.35,0.35,0.34,1.0);
uniform vec4 snow_color = vec4(0.92,0.94,0.97,1.0);

uniform float metallic = 0.0;
uniform float roughness = 0.1;

float hash13(vec3 p){
    p = fract(p * 0.1031);
    p += dot(p, p.yzx + 33.33);
    return fract((p.x + p.y) * p.z);
}

float value_noise(vec3 p){
    vec3 i = floor(p);
    vec3 f = fract(p);

    vec3 u = f*f*(3.0-2.0*f);

    float n000 = hash13(i + vec3(0.0,0.0,0.0));
    float n100 = hash13(i + vec3(1.0,0.0,0.0));
    float n010 = hash13(i + vec3(0.0,1.0,0.0));
    float n110 = hash13(i + vec3(1.0,1.0,0.0));
    float n001 = hash13(i + vec3(0.0,0.0,1.0));
    float n101 = hash13(i + vec3(1.0,0.0,1.0));
    float n011 = hash13(i + vec3(0.0,1.0,1.0));
    float n111 = hash13(i + vec3(1.0,1.0,1.0));

    float nx00 = mix(n000,n100,u.x);
    float nx10 = mix(n010,n110,u.x);
    float nx01 = mix(n001,n101,u.x);
    float nx11 = mix(n011,n111,u.x);

    float nxy0 = mix(nx00,nx10,u.y);
    float nxy1 = mix(nx01,nx11,u.y);

    return mix(nxy0,nxy1,u.z);
}

float fbm(vec3 p){
    float value = 0.0;
    float amplitude = 0.5;
    float frequency = 1.0;

    for(int i=0;i<8;i++){
        if(i>=octaves){ break; }

        value += amplitude * value_noise(p*frequency);
        frequency *= lacunarity;
        amplitude *= gain;
    }

    return value;
}

float planet_height(vec3 normal_dir){
    float n = fbm(normal_dir * noise_scale + noise_offset);
    n = n*2.0-1.0;
    return n;
}

varying float v_height;
varying vec3 v_normal_dir;

void vertex(){

    vec3 normal_dir = normalize(VERTEX);

    float h = planet_height(normal_dir);
    float displacement = h * height_scale;

    VERTEX = normal_dir * (radius + displacement);

    v_height = h;
    v_normal_dir = normal_dir;
}

vec3 biome_color(float h){

    float water_t = smoothstep(sea_level-0.2,sea_level,h);
    vec3 water = mix(deep_water_color.rgb,shallow_water_color.rgb,water_t);

    float beach_t = smoothstep(sea_level,sea_level+beach_size,h);
    vec3 lowland = mix(beach_color.rgb,grass_color.rgb,beach_t);

    float rock_t = smoothstep(0.3,snow_level,h);
    vec3 highland = mix(rock_color.rgb,snow_color.rgb,
        smoothstep(snow_level,1.0,h));

    vec3 land = mix(lowland,highland,rock_t);

    float land_mask = smoothstep(sea_level-0.005,sea_level+0.005,h);

    return mix(water,land,land_mask);
}

void fragment(){

    ALBEDO = biome_color(v_height);

    METALLIC = metallic;
    ROUGHNESS = roughness;

    float detail = fbm(v_normal_dir*noise_scale*4.0 + noise_offset*1.7);
    detail = detail*2.0-1.0;

    NORMAL = normalize(vec3(detail*0.15, -detail*0.15, 1.0));
}"

